---
import strings from "@utils/navigation.ts";
import Logo from "@components/logo.astro";
import Icon from "@components/ui/icons/Icon.astro";
import { SITE } from "@data/constants";

const socialLinks = [
  { name: "LinkedIn", url: strings.socialLinks.linkedIn, icon: "linkedIn", className: "text-sky-300 hover:text-sky-200" },
  { name: "Instagram", url: strings.socialLinks.instagram, icon: "instagram", className: "text-pink-300 hover:text-pink-200" },
].filter((link) => link.url && link.url !== "#");
---

<footer class="w-full bg-neutral-300 dark:bg-neutral-900">
  <div class="mx-auto w-full max-w-[85rem] px-4 py-6 sm:px-6 lg:px-12 2xl:max-w-(--breakpoint-2xl)">
    <div class="grid items-start gap-6 lg:grid-cols-[1.25fr_1fr_1.25fr]">
      <div>
        <a href="/" class="block w-52 sm:w-60" aria-label="Anthra Systems home">
          <Logo class="h-auto w-full" />
        </a>
        <p class="mt-3 max-w-sm text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
          Anthra Systems - Engineering Intelligence for the Physical World
        </p>
      </div>

      <div class="grid grid-cols-2 gap-5">
        {
          strings.footerLinks.map((section) => (
            <div>
              <h2 class="text-sm font-bold text-neutral-800 dark:text-neutral-100">{section.section}</h2>
              <ul class="mt-3 space-y-2">
                {section.links.map((link) => (
                  <li>
                    <a
                      href={link.url}
                      class="text-sm text-neutral-600 transition hover:text-[#ff5a00] dark:text-neutral-400 dark:hover:text-neutral-200"
                    >
                      {link.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <div class="lg:text-right">
        <p class="text-sm font-semibold text-neutral-800 dark:text-neutral-100">
          Have a real-world engineering challenge?
        </p>
        <div class="mt-3 flex flex-wrap gap-2 lg:justify-end">
          {
            socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={link.name}
                class:list={[
                  "inline-flex size-9 items-center justify-center rounded-lg border border-neutral-400/40 bg-black/30 transition hover:border-white/20 dark:border-neutral-700",
                  link.className,
                ]}
              >
                <Icon name={link.icon} />
              </a>
            ))
          }
          <a href="/contact" class="anthra-button-primary px-4 py-2 text-sm font-bold">
            Discuss Your Project
          </a>
        </div>
        <div class="mt-3 grid gap-1 text-sm text-neutral-600 dark:text-neutral-400">
          <a class="hover:text-[#ff5a00]" href="tel:+918788532123">+91 87885 32123</a>
          <a class="hover:text-[#ff5a00]" href="mailto:info@anthrasystems.com">info@anthrasystems.com</a>
          <a class="hover:text-[#ff5a00]" href="mailto:contact@anthrasystems.com">contact@anthrasystems.com</a>
          <a class="hover:text-[#ff5a00]" href="mailto:careers@anthrasystems.com">careers@anthrasystems.com</a>
        </div>
      </div>
    </div>

    <div class="mt-5 border-t border-neutral-400/40 pt-4 text-sm text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
      <p>&copy; <span id="current-year"></span> {SITE.title} Pvt. Ltd. All rights reserved.</p>
    </div>
  </div>

  <script>
    const element = document.getElementById("current-year");
    if (element) element.innerText = new Date().getFullYear().toString();
  </script>
</footer>
