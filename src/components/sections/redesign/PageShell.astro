---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  sections?: string[];
}

const { eyebrow, title, description, sections = [] } = Astro.props;
---

<section class="mx-auto max-w-[85rem] px-4 pb-14 pt-32 sm:px-6 lg:px-8 lg:pt-40">
  <div class="max-w-4xl">
    <p class="anthra-kicker">{eyebrow}</p>
    <h1 class="anthra-page-title mt-5 text-balance text-4xl text-neutral-100 sm:text-5xl lg:text-6xl">
      {title}
    </h1>
    <p class="mt-5 max-w-3xl text-pretty text-base leading-relaxed text-neutral-400 sm:text-lg">
      {description}
    </p>
  </div>

  {
    sections.length > 0 && (
      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {sections.map((section) => (
          <article class="anthra-shell-card p-5 sm:p-6">
            <p class="anthra-kicker">Phase 1 Shell</p>
            <h2 class="anthra-card-title mt-3 text-xl text-white">{section}</h2>
            <p class="mt-3 text-sm leading-relaxed text-neutral-400">
              Final page content, imagery, and interaction details will be built after Phase 1 approval.
            </p>
          </article>
        ))}
      </div>
    )
  }
</section>
