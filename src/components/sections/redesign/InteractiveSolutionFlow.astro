  @media (max-width: 1180px) {
    .interactive-flow__workspace {
      grid-template-columns: 1fr;
    }

    .interactive-flow__selector {
      grid-template-columns: repeat(5, minmax(14rem, 1fr));
      overflow-x: auto;
