---
import { Icons } from "./icons.ts";

interface Path {
  d: string;
  class?: string;
}

const { name, class: className, size = 24 } = Astro.props;

let icon = (Icons as any)[name] || {};

let paths: Path[] = icon.paths || [];
const width = icon.width ?? size;
const height = icon.height ?? size;
const classes = ["anthra-icon", icon.class, className].filter(Boolean).join(" ");
---

{
  icon ? (
    <svg
      class={classes}
      height={height}
      viewBox={icon.viewBox}
      width={width}
      fill={icon.fill}
      clip-rule={icon.clipRule}
      fill-rule={icon.fillRule}
      stroke={icon.stroke}
      stroke-width={icon.strokeWidth}
      stroke-linecap={icon.strokeLinecap}
      stroke-linejoin={icon.strokeLinejoin}
    ><title>{icon.title}</title>
      {paths.map((path: Path) => (
        <path d={path.d} class={path.class || ""} />
      ))}
    </svg>
  ) : (
    "Icon not found"
  )
}
