      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .integration-flow::before,
    .capability-visual-card__image {
      animation: none;
      transition: none;
    }
  }

  @keyframes capabilityFlowHorizontal {
    0%,
    100% {
      opacity: 0.35;
      transform: scaleX(0.72);
    }
    50% {
      opacity: 1;
      transform: scaleX(1);
    }
  }
</style>

<script>
  const capabilityItems = document.querySelectorAll("[data-capability-reveal]");
  const capabilityObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          capabilityObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.14 },
  );

  capabilityItems.forEach((item) => capabilityObserver.observe(item));

  const setupAutoCycle = (selector: string, itemSelector: string, activeClass = "is-active") => {
    document.querySelectorAll<HTMLElement>(selector).forEach((root) => {
      const items = Array.from(root.querySelectorAll<HTMLElement>(itemSelector));
      if (items.length < 2 || window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

      let index = 0;
      let isPaused = false;

      const setActive = (nextIndex: number) => {
        index = nextIndex % items.length;
        items.forEach((item, itemIndex) => item.classList.toggle(activeClass, itemIndex === index));
      };

      const timer = window.setInterval(() => {
        if (!isPaused) setActive(index + 1);
      }, 4600);

      root.addEventListener("mouseenter", () => {
        isPaused = true;
      });
      root.addEventListener("mouseleave", () => {
        isPaused = false;
      });
      root.addEventListener("focusin", () => {
        isPaused = true;
      });
      root.addEventListener("focusout", () => {
        isPaused = false;
      });
      root.addEventListener("click", (event) => {
        const target = (event.target as HTMLElement).closest<HTMLElement>(itemSelector);
        if (!target) return;
        setActive(items.indexOf(target));
        isPaused = true;
        window.setTimeout(() => {
          isPaused = false;
        }, 5200);
      });

      window.addEventListener("beforeunload", () => window.clearInterval(timer), { once: true });
    });
  };

  setupAutoCycle("[data-auto-capability]", "[data-capability-card]");
  setupAutoCycle("[data-auto-flow]", "[data-flow-layer]");
</script>
