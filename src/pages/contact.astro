---
import MainLayout from "@/layouts/MainLayout.astro";
import Icon from "@components/ui/icons/Icon.astro";

const projectTypes = [
  "Industrial/Machine System",
  "IoT/Connected System",
  "Edge AI/Vision",
  "Vehicle/Mobility",
  "Water/Agriculture",
  "Mechanical/Mechatronic",
  "Custom R&D/Prototype",
  "Not sure/consultation",
];

const contactDetails = [
  {
    icon: "mapPin",
    heading: "Kolhapur Office",
    label: "Anthra Systems Private Limited",
    detail: "Anthra Office, Bapu Building, Near Urban Bank, Kurundwad, Dst: Kolhapur, Maharashtra 416106",
  },
  {
    icon: "mapPin",
    heading: "Pune Office",
    label: "Anthra Systems Private Limited",
    detail: "Office no 904, 9th floor, Gera Imperium Rise, Wipro Circle, Hinjewadi Phase 2, Pune, Maharashtra 411057",
  },
  {
    icon: "envelopeOpen",
    heading: "Project Email",
    label: "Project inquiries and collaborations",
    detail: "info@anthrasystems.com",
    href: "mailto:info@anthrasystems.com",
  },
  {
    icon: "envelopeOpen",
    heading: "General Contact",
    label: "General communication",
    detail: "contact@anthrasystems.com",
    href: "mailto:contact@anthrasystems.com",
  },
  {
    icon: "chatBubble",
    heading: "Call / Message",
    label: "Quick project discussion",
    detail: "+91 8788532123",
    href: "tel:+918788532123",
  },
];

const socialLinks = [
  {
    name: "Instagram",
    url: "https://www.instagram.com/anthrasystems/",
    icon: "instagram",
    className: "text-pink-300 hover:text-pink-200",
  },
  {
    name: "LinkedIn",
    url: "https://www.linkedin.com/company/anthra-systems/",
    icon: "linkedIn",
    className: "text-sky-300 hover:text-sky-200",
  },
];
---

<MainLayout
  title="Contact | Anthra Systems"
  customDescription="Contact Anthra Systems to discuss intelligent systems across automation, IoT, edge AI, connected vehicles, mechatronics, and applied R&D."
  customOgTitle="Contact Anthra Systems"
>
  <section class="mx-auto max-w-[92rem] px-4 pb-14 pt-32 sm:px-6 lg:px-8 lg:pt-40">
    <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
      <div>
        <p class="anthra-kicker">Contact</p>
        <h1 class="anthra-page-title mt-5 text-balance text-4xl text-white sm:text-5xl lg:text-6xl">
          Let's Build Something Intelligent
        </h1>
        <p class="mt-6 max-w-2xl text-pretty text-base leading-relaxed text-neutral-400 sm:text-lg">
          Tell us about the machine, field asset, vehicle, device, prototype, or
          operational challenge you want to improve. Anthra can help define the
          system and engineer the practical path forward.
        </p>
        <div class="mt-8 grid gap-3 text-sm text-neutral-300">
          <a class="font-semibold text-[var(--anthra-orange)]" href="mailto:info@anthrasystems.com">
            info@anthrasystems.com
          </a>
          <a class="font-semibold text-neutral-300 transition hover:text-white" href="mailto:contact@anthrasystems.com">
            contact@anthrasystems.com
          </a>
          <p>Project inquiries, collaborations, R&D discussions, and technical consultations.</p>
        </div>
      </div>

      <form
        class="anthra-shell-card grid gap-4 p-5 sm:p-6"
        action="https://api.web3forms.com/submit"
        method="POST"
        data-web3forms-form
        data-loading-text="Sending..."
        data-success-message="Thanks. Your project inquiry has been sent."
        data-error-message="The form could not be submitted. Please email info@anthrasystems.com."
      >
        <input type="hidden" name="access_key" value="975b2f6a-340b-4706-a71e-b3a0c4ad4dec" />
        <input type="hidden" name="subject" value="Anthra Project Inquiry" />
        <input type="hidden" name="to" value="info@anthrasystems.com" />
        <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="grid gap-2 text-sm font-semibold text-neutral-200">
            Name
            <input name="name" required class="anthra-field rounded-lg" />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-neutral-200">
            Email
            <input name="email" type="email" required class="anthra-field rounded-lg" />
          </label>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="grid gap-2 text-sm font-semibold text-neutral-200">
            Phone
            <input name="phone" type="tel" required class="anthra-field rounded-lg" />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-neutral-200">
            Company
            <input name="company" class="anthra-field rounded-lg" />
          </label>
        </div>

        <label class="grid gap-2 text-sm font-semibold text-neutral-200">
          Project type
          <select name="project_type" required class="anthra-field rounded-lg">
            {projectTypes.map((type) => <option>{type}</option>)}
          </select>
        </label>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="grid gap-2 text-sm font-semibold text-neutral-200">
            Location
            <input name="location" required class="anthra-field rounded-lg" />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-neutral-200">
            Timeline
            <input name="timeline" required placeholder="Immediate, 1-3 months..." class="anthra-field rounded-lg" />
          </label>
        </div>

        <label class="grid gap-2 text-sm font-semibold text-neutral-200">
          Budget range <span class="text-neutral-500">optional</span>
          <input name="budget_range" class="anthra-field rounded-lg" />
        </label>

        <label class="grid gap-2 text-sm font-semibold text-neutral-200">
          Message / requirement
          <textarea name="message" rows="6" required class="anthra-field rounded-lg"></textarea>
        </label>

        <button class="anthra-button-primary px-5 py-3 text-sm font-bold disabled:cursor-wait disabled:opacity-70" type="submit">
          Discuss Your Project
        </button>
        <p class="min-h-5 text-sm text-neutral-400" data-form-status></p>
      </form>
    </div>
  </section>

  <section class="anthra-section mx-auto max-w-[92rem] px-4 sm:px-6 lg:px-8">
    <div class="mb-8 max-w-3xl">
      <p class="anthra-kicker">Contact Details</p>
      <h2 class="anthra-section-title mt-4 text-balance text-3xl text-white sm:text-4xl">
        Reach Anthra Systems directly.
      </h2>
      <p class="mt-4 text-base leading-relaxed text-neutral-400">
        For office visits, project discussions, partnerships, and engineering
        conversations, use the details below.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {contactDetails.map((item) => (
        <article class="anthra-shell-card flex gap-4 p-5 sm:p-6">
          <span class="inline-flex size-12 shrink-0 items-center justify-center rounded-lg border border-white/10 bg-black/45 text-[var(--anthra-orange)] shadow-[0_12px_34px_rgba(255,90,0,0.10)]">
            <Icon name={item.icon} />
          </span>
          <div>
            <h3 class="anthra-card-title text-lg text-white">{item.heading}</h3>
            <p class="mt-1 text-sm font-semibold text-neutral-300">{item.label}</p>
            {
              item.href ? (
                <a href={item.href} class="mt-3 inline-flex text-sm font-bold text-[var(--anthra-orange)] transition hover:text-white">
                  {item.detail}
                </a>
              ) : (
                <p class="mt-3 text-sm leading-relaxed text-neutral-400">{item.detail}</p>
              )
            }
          </div>
        </article>
      ))}
    </div>

    <article class="anthra-shell-card mt-5 flex flex-col justify-between gap-5 p-5 sm:flex-row sm:items-center sm:p-6">
      <div>
        <h3 class="anthra-card-title text-lg text-white">Connect with us</h3>
        <p class="mt-2 text-sm leading-relaxed text-neutral-400">
          Follow Anthra Systems for updates, projects, collaborations, and engineering work.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        {socialLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              "inline-flex items-center gap-2 rounded-lg border border-white/10 bg-black/45 px-4 py-2.5 text-sm font-bold transition hover:border-white/20",
              link.className,
            ]}
          >
            <Icon name={link.icon} />
            {link.name}
          </a>
        ))}
      </div>
    </article>
  </section>
</MainLayout>
