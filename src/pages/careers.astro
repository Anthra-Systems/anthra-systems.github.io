---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import careerHeroImage from "@images/careers-hero.png";

const roles = [
  ["Embedded Systems Intern/Engineer", "Firmware, sensors, device logic, testing, debugging, and hardware-adjacent engineering."],
  ["IoT & Software Developer", "Dashboards, APIs, device connectivity, telemetry, alerts, and web tools for connected systems."],
  ["AI/ML & Edge AI Researcher", "Computer vision, TinyML, model deployment, data pipelines, and real-world AI experiments."],
  ["Mechanical/Mechatronics Engineer", "Enclosures, mechanisms, mounting, field-fit design, prototyping, and integrated builds."],
  ["Automation & Control Engineer", "PLC/HMI, panels, drives, industrial logic, process automation, and machine integration."],
  ["R&D Associate", "Problem research, experiments, prototype documentation, testing, and cross-domain engineering support."],
];

const engagementTypes = ["Internship", "Full-time", "Project-based"];
---

<MainLayout
  title="Careers | Anthra Systems"
  customDescription="Join Anthra Systems as an intern, engineer, researcher, or builder working across custom electronics, embedded systems, IoT, edge AI, industrial automation, smart devices, and mechatronics."
>
  <section class="mx-auto max-w-[92rem] px-4 pb-14 pt-32 sm:px-6 lg:px-8 lg:pt-40">
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <p class="anthra-kicker">Careers</p>
        <h1 class="anthra-page-title mt-5 text-balance text-4xl text-white sm:text-5xl lg:text-6xl">
          Join a young engineering team building ambitious intelligent systems.
        </h1>
        <p class="mt-6 max-w-3xl text-pretty text-base leading-relaxed text-neutral-400 sm:text-lg">
          Anthra is for interns, engineers, researchers, and builders who want to
          work across computer engineering, electronics, mechanical/mechatronics,
          AI/ML, automation, IoT, edge AI, and real-world deployment.
        </p>
      </div>

      <div class="relative min-h-[24rem] overflow-hidden rounded-2xl border border-white/10 bg-neutral-950 shadow-[0_28px_90px_rgba(0,0,0,0.36)]">
        <Image
          src={careerHeroImage}
          alt="Anthra engineering lab workspace for R&D, embedded systems, and prototype development."
          class="absolute inset-0 h-full w-full object-cover"
          loading="eager"
          format="avif"
        />
        <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/18 to-transparent"></div>
        <div class="absolute bottom-0 left-0 max-w-xl p-6">
          <p class="anthra-kicker">Build With Us</p>
          <p class="anthra-display-title mt-3 text-xl text-white">
            R&D, embedded systems, automation, edge AI, and mechatronic builds.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="anthra-section mx-auto max-w-[92rem] px-4 sm:px-6 lg:px-8">
    <div class="mb-8 max-w-4xl">
      <p class="anthra-kicker">Open Roles</p>
      <h2 class="anthra-section-title mt-4 text-balance text-3xl text-white sm:text-4xl">
        We are always looking for enthusiastic young interns and full-time engineers / researchers.
      </h2>
    </div>
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {roles.map(([title, text]) => (
        <article class="anthra-shell-card group p-6 transition duration-300 hover:-translate-y-1 hover:border-[var(--anthra-orange)]/40 hover:shadow-[0_26px_80px_rgba(255,90,0,0.08)]">
          <p class="anthra-kicker">Open Direction</p>
          <h2 class="anthra-card-title mt-4 text-xl text-white">{title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-neutral-400">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="anthra-section mx-auto max-w-[92rem] px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <div>
        <p class="anthra-kicker">How to Apply</p>
        <h2 class="anthra-section-title mt-4 text-3xl text-white sm:text-4xl">
          Send links that show how you think and build.
        </h2>
        <p class="mt-5 text-base leading-relaxed text-neutral-400">
          Share a resume link, LinkedIn, GitHub, portfolio, Google Drive link,
          or project notes. File uploads are intentionally avoided for a lighter
          form flow.
        </p>
      </div>

      <form
        class="anthra-shell-card grid gap-4 p-5 sm:p-6"
        action="https://api.web3forms.com/submit"
        method="POST"
        data-web3forms-form
        data-loading-text="Sending..."
        data-success-message="Thanks. Your career interest has been sent."
        data-error-message="The form could not be submitted. Please email careers@anthrasystems.com."
      >
        <input type="hidden" name="access_key" value="932e16e6-08e8-44f9-a0e2-49422be4f8ab" />
        <input type="hidden" name="subject" value="Anthra Careers Inquiry" />
        <input type="hidden" name="to" value="careers@anthrasystems.com" />
        <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="grid gap-2 text-sm font-semibold text-neutral-200">
            Name
            <input name="name" required class="anthra-field rounded-lg" />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-neutral-200">
            Email
            <input name="email" type="email" required class="anthra-field rounded-lg" />
          </label>
        </div>

        <label class="grid gap-2 text-sm font-semibold text-neutral-200">
          Phone
          <input name="phone" type="tel" required class="anthra-field rounded-lg" />
        </label>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="grid gap-2 text-sm font-semibold text-neutral-200">
            Role interested
            <select name="role_interested" required class="anthra-field rounded-lg">
              {roles.map(([title]) => <option>{title}</option>)}
            </select>
          </label>
          <label class="grid gap-2 text-sm font-semibold text-neutral-200">
            Engagement type
            <select name="engagement_type" required class="anthra-field rounded-lg">
              {engagementTypes.map((type) => <option>{type}</option>)}
            </select>
          </label>
        </div>

        <label class="grid gap-2 text-sm font-semibold text-neutral-200">
          Resume link
          <input name="resume_link" required class="anthra-field rounded-lg" />
        </label>
        <label class="grid gap-2 text-sm font-semibold text-neutral-200">
          LinkedIn
          <input name="linkedin" class="anthra-field rounded-lg" />
        </label>
        <label class="grid gap-2 text-sm font-semibold text-neutral-200">
          GitHub or portfolio
          <input name="github_or_portfolio" class="anthra-field rounded-lg" />
        </label>
        <label class="grid gap-2 text-sm font-semibold text-neutral-200">
          Short note
          <textarea name="note" rows="4" class="anthra-field rounded-lg"></textarea>
        </label>
        <button class="anthra-button-primary px-5 py-3 text-sm font-bold disabled:cursor-wait disabled:opacity-70" type="submit">
          Send Application Interest
        </button>
        <p class="min-h-5 text-sm text-neutral-400" data-form-status></p>
      </form>
    </div>
  </section>
</MainLayout>
