---
import MainLayout from "../../../layouts/MainLayout.astro";
import "../../../interview-scheduler/scheduler.css";
---

<MainLayout title="Create Interview Schedule | Anthra Systems" robots="noindex,nofollow" showHeader={false}>
  <section class="scheduler-shell mx-auto max-w-4xl">
    <div class="scheduler-toolbar">
      <div><p class="anthra-kicker">Admin</p><h1 class="anthra-page-title mt-3 text-4xl">Create Interview Schedule</h1></div>
      <a class="scheduler-button" href="/admin/interviews">Back to Dashboard</a>
    </div>
    <div data-manage-status class="scheduler-alert">Ready.</div>
    <form data-schedule-form class="scheduler-panel scheduler-grid two mt-4">
      <label class="scheduler-field"><span class="scheduler-label-text">Schedule title <span class="scheduler-required">*</span></span><input class="scheduler-input" name="title" required /></label>
      <label class="scheduler-field"><span class="scheduler-label-text">Default opening title <span class="scheduler-required">*</span></span><input class="scheduler-input" name="roleName" required /></label>
      <label class="scheduler-field" style="grid-column:1/-1">Opening titles<textarea class="scheduler-textarea" name="openingTitles" placeholder="Embedded Engineer&#10;QA Intern&#10;Firmware Intern"></textarea></label>
      <label class="scheduler-field"><span class="scheduler-label-text">Interview date <span class="scheduler-required">*</span></span><input class="scheduler-input" type="date" name="interviewDate" required /></label>
      <div class="scheduler-field"><span>&nbsp;</span><button class="scheduler-button" data-confirm-schedule-date type="button">Confirm date</button></div>
      <input type="hidden" name="expiryAt" />
      <div class="scheduler-field"><span>Auto expiry</span><div class="scheduler-alert" data-expiry-preview>Select interview date.</div></div>
      <label class="scheduler-field">Status<select class="scheduler-select" name="status"><option value="draft">Draft</option><option value="active">Active</option></select></label>
      <label class="scheduler-field">Common meeting link<input class="scheduler-input" type="url" name="commonMeetingLink" placeholder="https://..." /></label>
      <label class="scheduler-field" style="grid-column:1/-1">Candidate instructions<textarea class="scheduler-textarea" name="description"></textarea></label>
      <div><button class="scheduler-button primary" type="submit">Create Schedule</button></div>
    </form>
  </section>
  <script>
    import "../../../interview-scheduler/pages/manage";
  </script>
</MainLayout>
