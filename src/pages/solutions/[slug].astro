              </div>
            </div>
          ))}
        </div>
      </article>
    </div>
  </section>

  <InteractiveSolutionFlow
    steps={interactiveFlowSteps}
    solutionTitle={solution.title}
    workflowTitle={workflowTitle}
    workflowSubtext={workflowSubtext}
    visualImageSrc={heroImage.src}
  />

  <section class="solution-section mx-auto max-w-[92rem] px-4 sm:px-6 lg:px-8">
    <div class="grid gap-7 lg:grid-cols-[0.34fr_0.66fr] lg:items-start">
      <div data-detail-reveal>
