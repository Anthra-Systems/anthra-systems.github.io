type DetailCard = { title: string; text: string };
type FlowStep = { title: string; text: string; icon?: string };
type WorkflowStep = {
  phase: "Source" | "Sense / Capture" | "Process" | "Show / Act" | "Outcome";
  title: string;
  description: string;
  visualKey: string;
  imageCropKey?: string;
  imageSrc?: string;
  inputs: string[];
  outputs: string[];
  detail: string;
  configures?: string[];
};

type FlowConfig = {
  steps: string[];
  inputs: string[];
  outputs: string[];
  modules: string[];
  outcomes: string[];
};

export function getStaticPaths() {
  return solutionSlugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const solution = getSolutionBySlug(slug);

if (!solution) {
  return Astro.redirect("/404");
}

