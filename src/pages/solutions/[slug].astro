        </h2>
        <p class="mt-4 text-sm leading-relaxed text-neutral-400">
          This space is part of the reusable layout so a future solution-specific implementation image can be added without redesigning the page.
        </p>
      </div>
      <div class="solution-supporting-slot" data-detail-reveal data-pending={supportingImagePending ? "true" : "false"}>
        {
          solution.supportingImage && !supportingImagePending ? (
            <Image
