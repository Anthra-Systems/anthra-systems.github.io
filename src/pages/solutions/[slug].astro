        <div class="absolute inset-0 bg-linear-to-t from-black/76 via-black/16 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-7">
          <div class="max-w-xl rounded-xl border border-white/10 bg-black/50 p-4 backdrop-blur">
            <p class="text-sm font-semibold text-white">Practical system, built around the real deployment.</p>
            <p class="mt-2 text-xs leading-relaxed text-neutral-300">
              Inputs, controller logic, dashboard, alerts, and field support planned together.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="solution-section mx-auto max-w-[92rem] px-4 sm:px-6 lg:px-8">
    <div class="grid gap-5 lg:grid-cols-[0.48fr_0.52fr]">
      <article class="solution-panel p-5 sm:p-6" data-detail-reveal>
        <p class="anthra-kicker">Problem</p>
        <h2 class="anthra-section-title mt-3 text-2xl text-white sm:text-3xl">
          What this system helps fix.
        </h2>
        <div class="mt-5 grid gap-3">
          {problemPoints.slice(0, 4).map((item) => (
            <div class="solution-compact-row">
              <span><Icon name="question" /></span>
              <div>
                <h3 class="anthra-card-title text-sm text-white">{item.title}</h3>
                <p class="mt-1 text-xs leading-relaxed text-neutral-400">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </article>

      <article class="solution-panel p-5 sm:p-6" data-detail-reveal>
        <p class="anthra-kicker">Outcome</p>
        <h2 class="anthra-section-title mt-3 text-2xl text-white sm:text-3xl">
          What the client gains.
        </h2>
        <div class="mt-5 grid gap-3">
          {outcomePoints.slice(0, 4).map((item) => (
            <div class="solution-compact-row">
              <span><Icon name="checkCircle" /></span>
              <div>
                <h3 class="anthra-card-title text-sm text-white">{item.title}</h3>
