<style>
  .solution-hero {
    background:
      radial-gradient(circle at 12% 22%, rgba(249, 115, 22, 0.1), transparent 27rem),
      radial-gradient(circle at 84% 18%, rgba(255, 255, 255, 0.045), transparent 26rem);
  }

  .solution-section {
    padding-top: clamp(2.5rem, 5vw, 4.5rem);
    padding-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }

  .solution-card,
  .solution-panel {
    border: 1px solid rgba(255, 255, 255, 0.1);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.038), rgba(255, 255, 255, 0.008)),
      rgba(10, 10, 10, 0.72);
    box-shadow: 0 22px 70px rgba(0, 0, 0, 0.22);
    backdrop-filter: blur(16px);
