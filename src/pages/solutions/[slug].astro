const category = solution.category ?? solution.area;
const heroImage = solution.heroImage ?? solution.image;
const subtitle = solution.subtitle ?? solution.description;
const flowConfig = flowConfigs[solution.slug] ?? {
  steps: solution.systemFlow?.map((step) => step.title) ?? ["Input", "Sensing", "Processing", "Dashboard", "Action"],
  inputs: solution.typicalInputs ?? solution.stack.slice(0, 4),
  outputs: solution.typicalOutputs ?? solution.features.slice(0, 4),
  modules: solution.stack.slice(0, 5),
  outcomes: solution.features.slice(0, 3),
};

const metaDescription = `${solution.description} Anthra Systems engineers practical physical-world systems across hardware, software, connectivity, automation, and deployment.`;

const iconForStep = (title: string) => {
  const lower = title.toLowerCase();
  if (lower.includes("camera") || lower.includes("vision") || lower.includes("ai")) return "aibrain";
  if (lower.includes("dashboard") || lower.includes("report")) return "dashboard";
  if (lower.includes("gateway") || lower.includes("connect")) return "iot";
  if (lower.includes("controller") || lower.includes("edge") || lower.includes("logic") || lower.includes("processing")) return "processor";
  if (lower.includes("vehicle") || lower.includes("gps") || lower.includes("field")) return "mapPin";
  if (lower.includes("test") || lower.includes("prototype") || lower.includes("study")) return "sparks";
  if (lower.includes("action") || lower.includes("alert") || lower.includes("output")) return "verified";
  return "tools";
};

const shortList = (items: string[], count = 3) => items.slice(0, count).join(", ");

const makeFlowSteps = (): FlowStep[] => {
  if (solution.customHowItWorksSteps) return solution.customHowItWorksSteps;
  if (solution.systemFlow) return solution.systemFlow;

  return flowConfig.steps.map((title, index) => {
    const isLast = index === flowConfig.steps.length - 1;
    let text = "Pass the right information to the next layer of the system.";

    if (index === 0) {
      text = `Start from the real source Anthra connects to for this system, with ${shortList(flowConfig.inputs, 2).toLowerCase()} considered early.`;
    } else if (index === 1) {
      text = `Capture useful signals such as ${shortList(flowConfig.inputs).toLowerCase()} without making the site harder to operate.`;
    } else if (index === 2) {
      text = "The controller, gateway, or edge device cleans the signal and runs the system logic close to the equipment.";
    } else if (index === 3 && !isLast) {
      text = `Turn the processed data into practical outputs like ${shortList(flowConfig.outputs).toLowerCase()}.`;
    } else if (isLast) {
      text = `Create the client result: ${shortList(flowConfig.outcomes, 2).toLowerCase()}.`;
    }

    return {
      title,
      text,
      icon: iconForStep(title),
    };
  });
};

const makeCards = (items: string[], text: (item: string) => string): DetailCard[] =>
  items.map((item) => ({ title: item, text: text(item) }));

const problemPoints =
  solution.customProblemPoints ??
  solution.problemPoints ??
  makeCards(solution.applications.slice(0, 3), (item) => `Teams managing ${item.toLowerCase()} often need clearer visibility, fewer manual checks, and faster issue response.`);

const outcomePoints =
  solution.customOutcomePoints ??
  makeCards(flowConfig.outcomes, (item) => `${item} for the real equipment, site, product, or operation where this system is deployed.`);

const systemFlow = makeFlowSteps();
const typicalInputs = solution.typicalInputs ?? flowConfig.inputs;
const typicalOutputs = solution.typicalOutputs ?? flowConfig.outputs;
const flowStageLabels = ["Source", "Sense / Capture", "Process", "Show / Act", "Outcome"];
const workflowFlowStageSets: Record<string, string[]> = {
  "industry-machine-systems": [industrialStage1.src, industrialStage2.src, industrialStage3.src, industrialStage4.src, industrialStage5.src],
  "water-agriculture-field-systems": [waterFieldStage1.src, waterFieldStage2.src, waterFieldStage3.src, waterFieldStage4.src, waterFieldStage5.src],
  "mobility-connected-vehicles": [mobilityStage1.src, mobilityStage2.src, mobilityStage3.src, mobilityStage4.src, mobilityStage5.src],
  "edge-ai-vision-systems": [visionStage1.src, visionStage2.src, visionStage3.src, visionStage4.src, visionStage5.src],
  "custom-rd-systems": [customRdStage1.src, customRdStage2.src, customRdStage3.src, customRdStage4.src, customRdStage5.src],
};
const workflowFlowStageImages = workflowFlowStageSets[solution.areaSlug];
const workflowFlowImageSrc = workflowFlowStageImages?.[0] ?? heroImage.src;

const workflowVisualKeys = (slug: string) => {
  if (slug.includes("water")) return ["water-source", "probe", "controller", "dashboard", "quality-result"];
  if (slug.includes("irrigation")) return ["field-source", "sensor", "controller", "pump-valve", "outcome"];
  if (slug.includes("aquaculture")) return ["water-source", "probe", "controller", "action", "quality-result"];
  if (slug.includes("pump")) return ["water-source", "sensor", "controller", "pump-valve", "outcome"];
  if (slug.includes("vehicle") || slug.includes("fleet") || slug.includes("cold-chain")) return ["vehicle", "gps", "gateway", "dashboard", "outcome"];
  if (slug.includes("vision") || slug.includes("camera") || slug.includes("detection") || slug.includes("surveillance")) return ["camera", "camera", "edge-ai", "action", "dashboard"];
  if (slug.includes("tinyml")) return ["sensor", "sensor", "edge-ai", "action", "outcome"];
  if (slug.includes("prototype") || slug.includes("rd") || slug.includes("proof-of-concept")) return ["idea", "prototype", "controller", "prototype", "outcome"];
  if (slug.includes("sensor-fusion")) return ["sensor", "sensor", "controller", "action", "outcome"];
  return ["machine-source", "sensor", "controller", "dashboard", "maintenance"];
};

const workflowTitleFor = (slug: string) => {
  const titles: Record<string, string> = {
    "machine-health-predictive-maintenance": "From Machine Signals to Maintenance Alerts",
    "industrial-monitoring-control": "From Machine Inputs to Live Control Visibility",
    "motor-drive-hmi-control": "From Operator Input to Safe Machine Operation",
    "machine-data-logger-dashboard": "From Machine Data to Operational Insight",
    "custom-machine-automation": "From Process Requirement to Automated Machine Action",
    "water-quality-monitoring": "From Water Parameters to Corrective Action",
    "smart-irrigation-fertigation": "From Field Conditions to Automated Irrigation",
    "aquaculture-monitoring": "From Pond Conditions to Farm Decisions",
    "pump-automation-protection": "From Water Level Signals to Protected Pump Control",
    "remote-field-asset-monitoring": "From Field Assets to Remote Visibility",
    "connected-vehicle-intelligence": "From Vehicle Data to Fleet Intelligence",
    "fleet-tracking-telematics": "From Vehicle Movement to Fleet Visibility",
    "vehicle-iot-gateway": "From Vehicle Signals to Connected Operations",
    "driver-vehicle-monitoring": "From Driver/Vehicle Signals to Safety Alerts",
    "cold-chain-transport-monitoring": "From Cargo Conditions to Transport Alerts",
    "edge-ai-vision-inspection": "From Camera Feed to Edge Decision",
    "object-detection-counting": "From Visual Input to Counted Objects",
    "safety-monitoring-camera": "From Site Camera Feed to Safety Action",
    "smart-surveillance-analytics": "From Camera Events to Operational Alerts",
    "low-power-tinyml-detection": "From Tiny Sensor Signals to Local Detection",
    "intelligent-product-rd": "From Product Idea to Tested Engineering Direction",
    "custom-embedded-mechatronic-prototype": "From Requirement to Tested Prototype",
    "ai-enabled-smart-device-development": "From Device Signals to Smart Product Behavior",
    "sensor-fusion-system": "From Multiple Sensor Streams to Better Awareness",
    "proof-of-concept-to-field-deployment": "From Concept to Field-Ready Trial",
  };

  return titles[slug] ?? "How This System Works in the Field";
};

const makeWorkflowSteps = (): WorkflowStep[] => {
  if (solution.flowSteps) return solution.flowSteps;

  const visualKeys = workflowVisualKeys(solution.slug);
  const processModule = flowConfig.modules.find((item) => /controller|gateway|edge|logic|processing|logger|model|unit/i.test(item)) ?? "Controller logic";
  const dashboardModule = flowConfig.modules.find((item) => /dashboard|hmi|alert|report|app|output/i.test(item)) ?? "Dashboard / alerts";
  const sensorModule = flowConfig.modules.find((item) => /sensor|input|camera|gps|probe|signal/i.test(item)) ?? "Input interface";
  const sourceContext = solution.applications.slice(0, 2);
  const actionOutputs = typicalOutputs.slice(0, 4);
  const capturedSignals = typicalInputs.map((item) => `${item} signal`).slice(0, 4);
  const processedSignals = actionOutputs.map((item) => `processed ${item.toLowerCase()}`).slice(0, 3);

  const inputsByPhase = [
    sourceContext.length ? sourceContext : [solution.area ?? category, "Site requirement"],
    typicalInputs.slice(0, 4),
    capturedSignals.length ? capturedSignals : typicalInputs.slice(0, 3),
    [processModule, "alarm condition", "operator need"].filter(Boolean),
    actionOutputs.length ? actionOutputs.slice(0, 3) : flowConfig.outcomes.slice(0, 3),
  ];
  const outputsByPhase = [
    typicalInputs.slice(0, 2).map((item) => `${item} point`).concat(["deployment context"]).slice(0, 4),
    capturedSignals,
    processedSignals.concat(["decision-ready status"]).slice(0, 4),
    actionOutputs,
    flowConfig.outcomes.slice(0, 4),
  ];
  const configureByPhase = [
    ["Site context", "Signal points", "Deployment constraints"],
    [sensorModule, "Sensor choice", "Input wiring", "Sampling plan"],
    [processModule, "Logic rules", "Connectivity"],
    [dashboardModule, "Alert behavior", "Control output"],
    ["Reports", "Action workflow", "Iteration path"],
  ];

  return systemFlow.slice(0, 5).map((step, index) => ({
    phase: (flowStageLabels[index] ?? `Step ${index + 1}`) as WorkflowStep["phase"],
    title: step.title,
    description: step.text,
    visualKey: visualKeys[index] ?? "source",
    imageCropKey: `stage-${index + 1}-snippet`,
    imageSrc: workflowFlowStageImages?.[index] ?? workflowFlowImageSrc,
    inputs: inputsByPhase[index] ?? typicalInputs.slice(0, 3),
    outputs: outputsByPhase[index] ?? typicalOutputs.slice(0, 3),
    detail: step.text,
    configures: configureByPhase[index] ?? flowConfig.modules.slice(0, 3),
  }));
};

const interactiveFlowSteps = makeWorkflowSteps();
const workflowTitle = solution.workflowTitle ?? workflowTitleFor(solution.slug);
const workflowSubtext =
  solution.workflowSubtitle ??
  "Select a step to see what is captured, what Anthra configures, and what action the system produces.";
const modules =
  solution.modulesBuilt ??
  solution.anthraBuildsModules ??
  makeCards(flowConfig.modules, (item) => `${item} selected and configured around the actual deployment requirement.`);
const customization =
  solution.customizationOptions?.slice(0, 4) ??
  makeCards(["Sensor / input choice", "Dashboard views", "Connectivity method", "Control or alert behavior"], (item) => `${item} can be tuned to suit the site, budget, users, and reliability needs.`);

const relatedSolutions =
  (solution.relatedSolutions
    ?.map((relatedSlug) => getSolutionBySlug(relatedSlug))
    .filter(Boolean) as typeof solutions) ??
  solutions
    .filter((item) => item.areaSlug === solution.areaSlug && item.slug !== solution.slug)
    .slice(0, 3);

const ctaText = solution.ctaText ?? "Discuss a Similar System";
const supportingImagePending = solution.supportingImagePending ?? true;
---

<MainLayout
  title={`${solution.title} | Anthra Systems`}
  customDescription={metaDescription}
  customOgTitle={`${solution.title} | Anthra Systems`}
>
  <section class="solution-hero mx-auto max-w-[92rem] px-4 pb-12 pt-32 sm:px-6 lg:px-8 lg:pb-14 lg:pt-40">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div data-detail-reveal>
        <p class="anthra-kicker">{category}</p>
        <h1 class="anthra-page-title mt-5 max-w-4xl text-balance text-4xl text-white sm:text-5xl lg:text-6xl">
          {solution.title}
        </h1>
        <p class="mt-5 max-w-3xl text-pretty text-base leading-relaxed text-neutral-300 sm:text-lg">
          {subtitle}
        </p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a href="/contact" class="anthra-button-primary px-5 py-3 text-center text-sm font-semibold">
            Discuss This System
          </a>
          <a href="/solutions" class="anthra-button-secondary px-5 py-3 text-center text-sm font-semibold">
            Back to Solutions
          </a>
        </div>
      </div>

      <div class="group relative min-h-[23rem] overflow-hidden rounded-2xl border border-white/10 bg-black shadow-[0_30px_100px_rgba(0,0,0,0.42)] lg:min-h-[30rem]" data-detail-reveal>
        <Image
          src={heroImage}
          alt={solution.alt}
          class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-[1.035]"
          loading="eager"
          format="avif"
