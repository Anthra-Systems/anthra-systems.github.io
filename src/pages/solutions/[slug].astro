    </div>
  </section>

  <section class="solution-section mx-auto max-w-[92rem] px-4 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between" data-detail-reveal>
      <div>
        <p class="anthra-kicker">Related Solutions</p>
        <h2 class="anthra-section-title mt-3 text-3xl text-white sm:text-4xl">Systems often discussed together.</h2>
      </div>
