  .solution-card,
  .solution-panel,
  .solution-cta,
  .solution-supporting-slot {
    border-radius: 1.15rem;
  }

  .solution-card {
    transition:
      transform 220ms ease,
      border-color 220ms ease,
      background 220ms ease;
  }

  .solution-card:hover {
    transform: translateY(-4px);
    border-color: rgba(251, 146, 60, 0.4);
    background: linear-gradient(145deg, rgba(22, 22, 22, 0.9), rgba(8, 8, 8, 0.78));
  }

  .solution-icon,
  .solution-mini-icon,
  .solution-compact-row span {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(251, 146, 60, 0.28);
    background: rgba(249, 115, 22, 0.1);
    color: rgb(253, 186, 116);
  }

  .solution-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 1rem;
  }

  .solution-mini-icon,
  .solution-compact-row span {
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 0.8rem;
  }

  .solution-icon :global(svg),
  .solution-mini-icon :global(svg),
  .solution-compact-row span :global(svg),
  .solution-pill-row :global(svg) {
    width: 1.15rem;
    height: 1.15rem;
    max-width: 1.15rem;
    max-height: 1.15rem;
  }

  .solution-icon :global(svg) {
    width: 1.35rem;
    height: 1.35rem;
    max-width: 1.35rem;
    max-height: 1.35rem;
  }

  .solution-compact-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem;
    align-items: start;
    border-radius: 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(0, 0, 0, 0.24);
    padding: 0.95rem;
  }

  .solution-pill-row {
    border-radius: 999px;
    border: 1px solid rgba(15, 23, 42, 0.1);
    background: rgba(248, 250, 252, 0.78);
    color: #1f2937;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .solution-pill-row {
    display: flex;
    min-height: 2.8rem;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 0.8rem;
  }

  .solution-pill-row svg {
    color: rgb(253, 186, 116);
  }

  .solution-cta {
    border: 1px solid rgba(251, 146, 60, 0.22);
    background:
      linear-gradient(135deg, rgba(249, 115, 22, 0.14), transparent 36%),
      linear-gradient(145deg, rgba(16, 16, 16, 0.95), rgba(0, 0, 0, 0.9));
    box-shadow: 0 26px 90px rgba(0, 0, 0, 0.35);
  }

  .solution-supporting-slot {
    min-height: 18rem;
    overflow: hidden;
    border: 1px dashed rgba(148, 163, 184, 0.5);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(241, 245, 249, 0.92)),
      #f8fafc;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
  }

  .solution-supporting-slot[data-pending="true"] {
    display: grid;
    place-items: center;
    padding: 2rem;
  }

  .solution-supporting-pending {
    width: 100%;
    max-width: 38rem;
    border-radius: 1rem;
    border: 1px solid rgba(15, 23, 42, 0.1);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(226, 232, 240, 0.66)),
      repeating-linear-gradient(135deg, rgba(15, 23, 42, 0.04) 0 1px, transparent 1px 14px);
    padding: 1.5rem;
  }

  [data-detail-reveal] {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 600ms ease,
      transform 600ms ease;
  }

  [data-detail-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

</style>

<script>
  const detailItems = document.querySelectorAll("[data-detail-reveal]");
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.14 },
  );

  detailItems.forEach((item) => revealObserver.observe(item));
</script>
