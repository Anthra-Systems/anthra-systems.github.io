              <p class="mt-3 max-w-xl text-sm leading-relaxed text-neutral-600">
                No placeholder or stock image is used. This slot is reserved for a clean, realistic, deployment-focused visual for this exact solution.
              </p>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <section class="solution-section mx-auto max-w-[92rem] px-4 sm:px-6 lg:px-8">
    <div class="grid gap-5 lg:grid-cols-2">
      <article class="solution-panel p-5 sm:p-6" data-detail-reveal>
        <p class="anthra-kicker">Applications</p>
