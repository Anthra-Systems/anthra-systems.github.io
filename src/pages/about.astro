---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import founderImage from "@images/CEO Photo.png";

const direction = [
  {
    label: "Vision",
    title: "To become a trusted engineering partner for intelligent physical-world systems.",
    text: "Anthra aims to help teams build connected, practical, field-ready systems across machines, infrastructure, mobility, agriculture, edge AI, and new product R&D.",
  },
  {
    label: "Mission",
    title: "To turn real-world engineering challenges into deployable intelligent systems.",
    text: "We combine applied R&D, hardware, software, mechanical/mechatronic design, automation, IoT, edge intelligence, testing, and productization into one practical engineering process.",
  },
];

const beliefs = [
  ["Engineering before appearance", "Good systems begin with the real constraints: machines, sites, users, environment, cost, reliability, and deployment."],
  ["R&D with a practical finish", "Exploration matters only when it can move toward a build that can be tested, improved, and used."],
  ["Integrated system thinking", "Hardware, software, mechanical design, automation, and AI are planned as one connected engineering problem."],
];
---

<MainLayout
  title="About Anthra Systems | Engineering Intelligence for the Physical World"
  customDescription="Anthra Systems is an applied engineering and R&D company building custom electronics, embedded systems, IoT solutions, industrial automation, smart devices, edge AI, and connected systems for real-world physical challenges."
>
  <section class="mx-auto max-w-[92rem] px-4 pb-14 pt-32 sm:px-6 lg:px-8 lg:pt-40">
    <div class="grid gap-10 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
      <div>
        <p class="anthra-kicker">About Anthra Systems</p>
        <h1 class="anthra-page-title mt-5 text-balance text-4xl text-white sm:text-5xl lg:text-6xl">
          Applied engineering for intelligent physical-world systems.
        </h1>
        <p class="mt-6 max-w-3xl text-pretty text-base leading-relaxed text-neutral-400 sm:text-lg">
          Anthra Systems brings applied R&D, embedded technology, automation,
          IoT, mechatronics, connected machines, and edge intelligence together
          for clients solving real-world engineering challenges.
        </p>
      </div>

      <div class="anthra-shell-card p-6 sm:p-8">
        <p class="anthra-display-title text-balance text-2xl text-white sm:text-3xl">
          We are a <span class="text-[var(--anthra-orange)]">young engineering startup</span>
          with a <span class="text-[var(--anthra-orange)]">bold vision</span>
          - combining practical industry experience with fresh young minds to
          build ambitious, intelligent systems for real-world challenges.
        </p>
      </div>
    </div>
  </section>

  <section class="anthra-section mx-auto max-w-[92rem] px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
      <div class="overflow-hidden rounded-2xl border border-white/10 bg-neutral-950">
        <Image
          src={founderImage}
          alt="Mr. Subhash Alase, Founder and Director of Anthra Systems"
          class="aspect-[4/3] w-full object-cover"
          loading="lazy"
          format="avif"
        />
        <div class="border-t border-white/10 bg-black/55 p-5">
          <h3 class="anthra-card-title text-2xl text-white">
            Mr. Subhash Alase
          </h3>
          <p class="mt-1 text-sm font-bold uppercase tracking-[0.18em] text-[var(--anthra-orange)]">
            Founder & Director
          </p>
        </div>
      </div>
      <div>
        <p class="anthra-kicker">Founder Credibility</p>
        <h2 class="anthra-section-title mt-4 text-3xl text-white sm:text-4xl">
          Led by practical industry experience.
        </h2>
        <p class="mt-5 text-base leading-relaxed text-neutral-400 sm:text-lg">
          Mr. Subhash Alase brings over 40 years of experience in industrial
          automation, mechatronic system design, and embedded systems. That
          experience shapes Anthra's practical view of machines, deployment,
          maintenance, and engineering decisions that must work outside a lab.
        </p>
      </div>
    </div>
  </section>

  <section class="anthra-section mx-auto max-w-[92rem] px-4 sm:px-6 lg:px-8">
    <div class="grid gap-5 md:grid-cols-2">
      {direction.map((item) => (
        <article class="anthra-shell-card p-6 sm:p-8">
          <p class="anthra-kicker">{item.label}</p>
          <h2 class="anthra-section-title mt-4 text-2xl text-white sm:text-4xl">
            {item.title}
          </h2>
          <p class="mt-5 text-base leading-relaxed text-neutral-400">{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="anthra-section mx-auto max-w-[92rem] px-4 sm:px-6 lg:px-8">
    <div class="grid gap-5 md:grid-cols-3">
      {beliefs.map(([title, text]) => (
        <article class="anthra-shell-card p-6">
          <p class="anthra-kicker">Belief</p>
          <h2 class="anthra-card-title mt-4 text-xl text-white">{title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-neutral-400">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-[92rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="rounded-2xl border border-white/10 bg-linear-to-br from-neutral-900 via-neutral-950 to-black p-6 sm:p-10 lg:p-12">
      <p class="anthra-kicker">Ambition</p>
      <h2 class="anthra-display-title mt-4 max-w-4xl text-balance text-3xl text-white sm:text-4xl">
        To help clients move from unclear technical challenges to engineered systems that are testable, understandable, and field-ready.
      </h2>
      <p class="mt-5 max-w-3xl text-base leading-relaxed text-neutral-400 sm:text-lg">
        Anthra's ambition is practical and long-term: combine experienced
        engineering judgment with young technical energy to build useful systems
        for real-world deployment.
      </p>
    </div>
  </section>
</MainLayout>
