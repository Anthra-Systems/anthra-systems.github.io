  .rnd-scenario-card:hover,
  .rnd-scenario-card.is-active {
    transform: translateY(-3px);
    border-color: rgba(251, 146, 60, 0.42);
    background:
      linear-gradient(145deg, rgba(249, 115, 22, 0.1), rgba(255, 255, 255, 0.025)),
      rgba(10, 10, 10, 0.84);
  }

  .rnd-scenario-card svg,
  .rnd-example svg {
    color: rgb(253, 186, 116);
  }

  .rnd-scenario-card span {
    color: white;
    font-size: 0.95rem;
    font-weight: 800;
  }

  .rnd-scenario-card small {
    color: rgb(163, 163, 163);
    font-size: 0.78rem;
    line-height: 1.55;
