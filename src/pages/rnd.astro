      opacity 600ms ease,
      transform 600ms ease;
  }

  .js [data-rnd-reveal] {
    opacity: 1;
    transform: translateY(0);
  }

  [data-rnd-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes rndFlow {
    0%,
    100% {
      opacity: 0.35;
      transform: scaleY(0.72);
    }
    50% {
      opacity: 1;
      transform: scaleY(1);
