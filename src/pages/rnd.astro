  .rnd-approach,
  .rnd-simple-flow {
    position: relative;
    display: grid;
    gap: 0.85rem;
  }

  .rnd-approach::before,
  .rnd-simple-flow::before {
    content: "";
    position: absolute;
    left: 1.7rem;
    top: 2rem;
    bottom: 2rem;
    width: 1px;
    background: linear-gradient(180deg, rgba(251, 146, 60, 0.1), rgba(251, 146, 60, 0.82), rgba(251, 146, 60, 0.1));
    animation: rndFlow 3.6s ease-in-out infinite;
  }

  .rnd-flow-card,
  .rnd-simple-card,
  .rnd-example {
    position: relative;
    border-radius: 1rem;
    padding: 1rem;
    transition:
      transform 220ms ease,
      border-color 220ms ease,
      background 220ms ease;
  }

  .rnd-flow-card:hover,
  .rnd-flow-card.is-active,
